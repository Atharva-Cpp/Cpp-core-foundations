#include<iostream>
using namespace std;
int main()
{
   double balance=5000.0;
   int temp=0;
   double x,y;
   cout<<"Input a number for following:\n '1' To show current balance\n '2' To deposit amount\n '3'To withdraw money\n";
   cin>>temp;
   switch (temp)
   {
      case 1:cout<<"Balance: "<<balance<<endl;
               break;
      case 2:cout<<"Input the amount to be deposited: ";
             cin>>x;
             balance+=x;
             cout<<"Balance:"<<balance;
                 break;
      case 3:cout<<"Input amount to withdraw:";
             cin>>y;
             if (y<=balance)
             {
                 cout<<"amount withdrawn "<<y<<endl;
                 balance-=y;
                 cout<<"Balance:"<<balance;
             }
             else
             {
                 cout<<"balance insufficient";
             }
                 break;
       default:cout<<"Invalid input";
               break;
   }   
   return 0;
}
